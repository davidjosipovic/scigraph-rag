# === ORKG Configuration ===
# ORKG SPARQL endpoint (public)
ORKG_SPARQL_ENDPOINT=https://orkg.org/triplestore
# Set to "true" to use a local RDF file instead of the remote endpoint
USE_LOCAL_RDF=false
# Path to local RDF dump (only used if USE_LOCAL_RDF=true)
LOCAL_RDF_PATH=data/orkg_dump.nt

# === Ollama Configuration ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Timeout in seconds for LLM generation
OLLAMA_TIMEOUT=120

# === API Configuration ===
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# === Retrieval Settings ===
# Max number of papers to retrieve per query
MAX_RESULTS=10
