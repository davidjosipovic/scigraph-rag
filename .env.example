# === ORKG Configuration ===
# ORKG SPARQL endpoint (public)
ORKG_SPARQL_ENDPOINT=https://orkg.org/triplestore
# Set to "true" to use a local RDF file instead of the remote endpoint
USE_LOCAL_RDF=false
# Path to local RDF dump (only used if USE_LOCAL_RDF=true)
LOCAL_RDF_PATH=data/orkg_dump.nt
# Timeout in seconds for individual SPARQL queries
SPARQL_TIMEOUT=10

# === Ollama Configuration ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Timeout in seconds for LLM generation
OLLAMA_TIMEOUT=120

# === API Configuration ===
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins.
# For production, set to your frontend URL, e.g.: https://myapp.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# === Retrieval Settings ===
# Max number of papers to retrieve per SPARQL query
MAX_RESULTS=5
# Max number of papers forwarded to the LLM context window
MAX_CONTEXT_PAPERS=8

# === Concurrency ===
# Max concurrent /ask requests allowed to run the full pipeline.
# Ollama is single-threaded; keep this low to avoid saturating it.
MAX_CONCURRENT_REQUESTS=3
